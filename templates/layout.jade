include ../mixins/postNavigation.jade

doctype html
block vars
  - var bodyclass = null;
html(lang='en')
  head
    block head
      meta(charset='utf-8')
      meta(http-equiv='X-UA-Compatible', content='IE=edge,chrome=1')
      meta(name='viewport', content='width=device-width')
      title
        block title
          = locals.name
      link(rel='alternate', href=locals.url+'/feed.xml', type='application/rss+xml', title=locals.description)
      link(rel='stylesheet', href='http://fonts.googleapis.com/css?family=Lora:400,700,400italic,700italic|Anonymous+Pro:400,700,400italic,700italic|Merriweather:400,700,300')
      link(rel='stylesheet', href='/compiled/css/main.css')
      <link href='http://fonts.googleapis.com/css?family=Lora' rel='stylesheet' type='text/css'>
      script(type="text/javascript" src="/js/vendor/balalaika.js")
      script(type="text/javascript" src="/js/vendor/better-simple-slideshow.js")
      script(type="text/javascript" src="/js/vendor/sloth.js")
      script(type="text/javascript" src="/js/vendor/microajax.js")
      script(type="text/javascript" src="/js/balalaika_extensions.js")
      script(type="text/javascript" src="/js/galleries.js")
      script(type="text/javascript" src="/js/lazy_loading.js")
      script(type="text/javascript" src="/js/main.js")
  body(class=bodyclass)
    header.header
      block header
        div.logo
          h1
            a(href=locals.url)= locals.name
          p.description= locals.description
    block content
    footer
      block footer
        section.about
          div.me
            p Canned Nerd wird geschrieben und veröffentlicht von halfdane.
            p Mein Name ist halfdane und meine E-Mail-Adresse ist &lt;name>@gmx.net.
            p
              a(href="/about.html") Weitere Informationen.
          div.contents
            p Ohne weitere Absprachen können alle Inhalte von diesen Seiten von dir für nichtkommerzielle Zwecke genutzt werden, solange du nicht so tust, als wärst du der Urheber
              a(href="http://creativecommons.org/licenses/by-nc-sa/3.0/de/")  (Creative Commons Lizenz).
          div.sources
            p Alle meine Quelltexte dürfen studiert, benutzt  und weitergegeben werden, solange die Benutzer des abgeleiteten Werks dieselben Rechte behalten
              a(href="http://www.gnu.de/documents/gpl.de.html")  (General Public License v.3).

section.copy
          p &copy; #{ new Date().getFullYear() } #{ locals.owner } &mdash; powered by&nbsp;
            a(href='https://github.com/jnordberg/wintersmith') Wintersmith
