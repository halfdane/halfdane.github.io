<div class="tile post">
    {% if post.image %}{% image {{post.image}} "{{post.title}}" "thumbnail" %}{% endimage %}{% endif %}
    <div class="text">
        <h3>{{ post.title }}</h3><span class="date">– {{ post.date | date: "%-d %B %Y" }} –</span>
        <div class="excerpt">{{ post.excerpt }}</div>
    </div>
    <a class="postlink" href="{{ BASE_PATH }}{{ post.url }}">Lesen</a>
</div>
